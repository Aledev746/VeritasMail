{
  "manifest_version": 3,
  "name": "VeritasMail",
  "version": "1.1",
  "description": "Rilevamento email phishing e report forense con consigli di sicurezza",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VeritasMail Dashboard"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/Icona 16x16.png",
    "48": "icons/icona 48x48.png",
    "128": "icons/icona 128x128.png"
  }
}
